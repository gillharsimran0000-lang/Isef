{
  "name": "pilengine",
  "private": true,
  "version": "1.0.0",
  "description": "PILENGINE; Scientific Compost Intelligence Platform",
  "workspaces": [
    "simulation-engine",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=backend",
    "dev:all": "concurrently -n API,WEB -c green,cyan \"npm:dev:api\" \"npm:dev\"",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "test": "npm run test --workspace=simulation-engine",
    "typecheck": "tsc -p simulation-engine --noEmit && tsc -p frontend --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "framer-motion": "^12.42.2"
  }
}
